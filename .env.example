# RemoteDesk Dashboard PWA — Environment Variables
# For Lovable Cloud: these are auto-managed. For self-hosting: copy to .env.local

# ---- Supabase (auth, devices, sessions, billing) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your-anon-publishable-key...
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-only (used by SSR / server functions). Never commit real values.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your-anon-publishable-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...

# ---- RemoteDesk Backend API + Signaling ----
# The Node.js backend runs separately (Docker/VPS or Cloudflare Tunnel for local dev).
# Used by the dashboard signaling service to initiate WebRTC sessions.
#
# Local dev with Cloudflare Tunnel:
#   VITE_API_URL=https://random.trycloudflare.com
#   VITE_SIGNALING_URL=https://random.trycloudflare.com
#
# Production VPS:
#   VITE_API_URL=https://api.yourdomain.com
#   VITE_SIGNALING_URL=https://api.yourdomain.com
VITE_API_URL=http://localhost:5000
VITE_SIGNALING_URL=http://localhost:5000

# Feature flags
VITE_DEMO_FALLBACK=true
