# Lovable Cloud (Supabase) — runtime config

# These are auto-managed when running on Lovable Cloud. For self-hosting,
# copy this file to .env.local and fill in your own Supabase project values.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your-anon-publishable-key...
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-only (used by SSR / server functions). Never commit real values.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...your-anon-publishable-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...
